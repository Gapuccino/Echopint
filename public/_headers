/*
  X-DNS-Prefetch-Control: on
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com; connect-src 'self' https://cloudflareinsights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate

# Next.js hashed static assets — safe to cache for 1 year
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Static images
/*.webp
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# API routes — never cache
/api/*
  Cache-Control: private, no-cache, no-store

# VCard No Index
/es/card/*
  X-Robots-Tag: noindex, nofollow
/en/card/*
  X-Robots-Tag: noindex, nofollow
